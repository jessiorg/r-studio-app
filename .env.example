# RStudio Server - Environment Variables
# Copy this file to .env and configure for your environment

# RStudio Configuration
RSTUDIO_USER=rstudio
RSTUDIO_PASSWORD=rstudio123  # CHANGE THIS!
RSTUDIO_PORT=8787

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8787

# Resource Limits
MEMORY_LIMIT=4G
CPU_LIMIT=4
CPU_RESERVATION=2
MEMORY_RESERVATION=2G

# Session Configuration
RSESSION_TIMEOUT=120  # minutes
RSESSION_PROXY_TIMEOUT=120  # seconds

# Paths
HOME_DIR=/data/rstudio-server/home
LIBS_DIR=/data/rstudio-server/libs
CONFIG_DIR=/data/rstudio-server/config

# Security
DISABLE_AUTH=false
AUTH_REQUIRED_USER_GROUP=rstudio-users
AUTH_MINIMUM_USER_ID=500

# CORS (if needed)
CORS_ORIGINS=http://localhost,https://your-domain.com

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/rstudio